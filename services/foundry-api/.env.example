DATABASE_URL=
FOUNDRY_BACKEND_SHARED_SECRET=
AI_PROVIDER=openai               # openai | anthropic | gemini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=               # only needed if AI_PROVIDER=anthropic
GEMINI_API_KEY=                  # only needed if AI_PROVIDER=gemini
OPENAI_MODEL=gpt-4o
CHECKLIST_AI_PROVIDER=openai     # openai, azure, or mock for local no-key smoke tests
OPENAI_REALTIME_API_KEY=         # optional; falls back to OPENAI_API_KEY
OPENAI_REALTIME_MODEL=gpt-realtime
AZURE_OPENAI_REALTIME_ENDPOINT=  # e.g. https://resource.openai.azure.com/openai/v1, not services.ai.azure.com
AZURE_OPENAI_REALTIME_API_KEY=
AZURE_OPENAI_REALTIME_DEPLOYMENT= # e.g. gpt-realtime-1.5 deployment name
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT= # optional Azure transcribe deployment; blank uses whisper-1
ZOOM_RTMS_ENABLED=false
ZOOM_RTMS_CLIENT_ID=
ZOOM_RTMS_CLIENT_SECRET=
ZOOM_RTMS_WEBHOOK_SECRET_TOKEN=
OPENAI_WEB_SEARCH_MODEL=          # optional; defaults to OPENAI_MODEL
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-pro
GEMINI_WEB_SEARCH_MODEL=          # optional; defaults to GEMINI_MODEL
