# Server
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info

# Database
# Must match the root .env.local DATABASE_URL.
DATABASE_URL=

# Next.js backend auth
# Must match the root .env.local FOUNDRY_BACKEND_SHARED_SECRET.
FOUNDRY_BACKEND_SHARED_SECRET=

# AI provider
AI_PROVIDER=openai               # openai | anthropic | gemini
OPENAI_API_KEY=                  # required when AI_PROVIDER=openai
ANTHROPIC_API_KEY=               # required when AI_PROVIDER=anthropic
GEMINI_API_KEY=                  # required when AI_PROVIDER=gemini

# AI models and behavior
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-pro
OPENAI_WEB_SEARCH_MODEL=         # optional; defaults to OPENAI_MODEL
GEMINI_WEB_SEARCH_MODEL=         # optional; defaults to GEMINI_MODEL
GEMINI_THINKING_LEVEL=           # optional Gemini thinking control
AI_REQUEST_TIMEOUT_SECONDS=45

# Live-call checklist
CHECKLIST_AI_PROVIDER=openai     # openai | azure | mock
OPENAI_REALTIME_API_KEY=         # optional; falls back to OPENAI_API_KEY
OPENAI_REALTIME_MODEL=gpt-realtime

# Azure OpenAI realtime checklist
AZURE_OPENAI_REALTIME_ENDPOINT=  # e.g. https://resource.openai.azure.com/openai/v1
AZURE_OPENAI_REALTIME_API_KEY=
AZURE_OPENAI_REALTIME_DEPLOYMENT=
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT=

# Recall.ai
RECALL_API_KEY=
RECALL_REGION=us-west-2
RECALL_WEBHOOK_SECRET=

# Fireflies
FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=

# Otter.ai
OTTER_API_KEY=
OTTER_WEBHOOK_SECRET=
