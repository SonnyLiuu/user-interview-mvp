# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database
# Use the same DATABASE_URL in services/foundry-api/.env.local.
DATABASE_URL=                    # Neon pooled connection string
DATABASE_URL_UNPOOLED=           # Neon direct connection string for migrations

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# FastAPI backend
# FOUNDRY_BACKEND_SHARED_SECRET must match services/foundry-api/.env.local.
FOUNDRY_API_BASE_URL=http://127.0.0.1:8001
FOUNDRY_BACKEND_SHARED_SECRET=

# AI provider
AI_PROVIDER=openai               # openai | anthropic | gemini
OPENAI_API_KEY=                  # required when AI_PROVIDER=openai
ANTHROPIC_API_KEY=               # required when AI_PROVIDER=anthropic
GEMINI_API_KEY=                  # required when AI_PROVIDER=gemini

# AI models
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-pro
OPENAI_WEB_SEARCH_MODEL=         # optional; defaults to OPENAI_MODEL
GEMINI_WEB_SEARCH_MODEL=         # optional; defaults to GEMINI_MODEL
GEMINI_THINKING_LEVEL=           # optional Gemini thinking control
AI_REQUEST_TIMEOUT_SECONDS=45    # timeout in seconds for AI API calls

# Person research
FIRECRAWL_API_KEY=               # required for person research crawl

# Desktop notetaker
FOUNDRY_DESKTOP_API_PUBLIC_URL=  # optional public FastAPI URL for desktop live streams
FOUNDRY_OVERLAY_INSTALLER_URL=   # optional hosted Windows installer URL

# Live-call checklist
CHECKLIST_AI_PROVIDER=openai     # openai | azure | mock
OPENAI_REALTIME_API_KEY=         # optional; falls back to OPENAI_API_KEY
OPENAI_REALTIME_MODEL=gpt-realtime

# Azure OpenAI realtime checklist
AZURE_OPENAI_REALTIME_ENDPOINT=  # e.g. https://resource.openai.azure.com/openai/v1
AZURE_OPENAI_REALTIME_API_KEY=
AZURE_OPENAI_REALTIME_DEPLOYMENT=
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT=

# Zoom RTMS
ZOOM_RTMS_ENABLED=false
ZOOM_RTMS_CLIENT_ID=
ZOOM_RTMS_CLIENT_SECRET=
ZOOM_RTMS_WEBHOOK_SECRET_TOKEN=

# Recall.ai (meeting bot provider)
RECALL_API_KEY=
RECALL_REGION=us-west-2
RECALL_WEBHOOK_SECRET=

# Fireflies (meeting transcription provider)
FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=

# Otter.ai (meeting transcription provider)
OTTER_API_KEY=
OTTER_WEBHOOK_SECRET=
