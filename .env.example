NEXT_PUBLIC_SITE_URL=
DATABASE_URL=                    # Neon pooled
DATABASE_URL_UNPOOLED=           # Neon direct (for migrations)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
AI_PROVIDER=openai               # openai | anthropic | gemini — defaults to openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=               # only needed if AI_PROVIDER=anthropic
GEMINI_API_KEY=                  # only needed if AI_PROVIDER=gemini
OPENAI_MODEL=gpt-4o
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_WEB_SEARCH_MODEL=          # optional; defaults to OPENAI_MODEL
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash
GEMINI_WEB_SEARCH_MODEL=          # optional; defaults to GEMINI_MODEL
FIRECRAWL_API_KEY=               # required for person research crawl
FOUNDRY_API_BASE_URL=http://127.0.0.1:8001
FOUNDRY_BACKEND_SHARED_SECRET=
